# monitor service — internal use only

# Postgres connection string (required)
MONITOR_POSTGRES_URL=postgresql://user:pass@host:5432/monitor_db
# Optional: connection pool size (default 10)
MONITOR_POSTGRES_POOL_MAX=10

# LLM encryption — required for storing API keys per project.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MASTER_ENCRYPTION_KEY=
# Note: ANTHROPIC_API_KEY is no longer used globally. Each project
# configures its own API key in project_settings via the /v1/settings
# endpoint (available in M.2.e).

# pg-boss uses MONITOR_POSTGRES_URL (same as pg client above) — no extra config needed.
# To disable the background worker (e.g. in CI or read-only deployments):
# MONITOR_WORKER_DISABLED=true

# Resend (email)
RESEND_API_KEY=re_...

# Slack (optional — configured per org in DB)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# App
NEXT_PUBLIC_APP_URL=https://your-monitor-domain.com
