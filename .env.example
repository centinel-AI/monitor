# monitor environment template — internal AI monitoring service (Next.js API-only).
# MONITOR_* variables for the service. The web console and engine live in sibling Grauss repos.

# ── monitor service (Next.js) ──────────────────────────────────────────────────
# Host port for the Compose `monitor` service.
MONITOR_PORT=3001

# ── monitor Postgres (Compose service monitor-postgres; image pgvector/pgvector:pg18) ──
# The service reads a single connection string from MONITOR_POSTGRES_URL.
# Local `pnpm dev` on the host: point it at localhost and publish MONITOR_POSTGRES_PORT (5433).
# Compose service `monitor` builds the URL from the variables below targeting host monitor-postgres:5432.
# Volume is mounted at /var/lib/postgresql (required for PG 18+ layout). Persisted as grauss-monitor-postgres-data.
# Upgrading from an older mount layout: task monitor:db:wipe then task monitor:db:up (local data loss).
MONITOR_POSTGRES_URL=postgresql://monitor:monitor@localhost:5433/monitor
# Compose-only: credentials/port for the monitor-postgres container and the URL it composes.
MONITOR_POSTGRES_USER=monitor
MONITOR_POSTGRES_PASSWORD=monitor
MONITOR_POSTGRES_DB=monitor
MONITOR_POSTGRES_PORT=5433
# Optional: connection pool size (default 10).
MONITOR_POSTGRES_POOL_MAX=10

# ── LLM key encryption ─────────────────────────────────────────────────────────
# Required for storing per-project API keys (AES-256-GCM). Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Note: ANTHROPIC_API_KEY is no longer used globally. Each project configures its
# own API key in project_settings via the /v1/settings endpoint.
MASTER_ENCRYPTION_KEY=

# ── Background worker (pg-boss) ────────────────────────────────────────────────
# pg-boss uses MONITOR_POSTGRES_URL (same as the pg client) — no extra config needed.
# To disable the background worker (e.g. in CI or read-only deployments):
# MONITOR_WORKER_DISABLED=true

# ── Service-to-service auth ────────────────────────────────────────────────────
# Shared token portal → monitor. Must match EXACTLY the portal's WEB_MONITOR_SERVICE_TOKEN.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MONITOR_SERVICE_TOKEN=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Transactional email for outgoing notifications.
RESEND_API_KEY=re_...

# ── Slack (optional — configured per project in DB) ────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-monitor-domain.com
